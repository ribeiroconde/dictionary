{
  "name": "ribeiroconde/filament-dictionary",
  "description": "A step-by-step wizard to generate full Eloquent and Filament resources straight from the Filament panel",
  "keywords": [
    "ribeiroconde",
    "filament",
    "dictionary",
    "plugin",
    "generator"
  ],
  "homepage": "https://github.com/ribeiroconde/filament-dictionary",
  "license": "MIT",
  "authors": [
    {
      "name": "Cristian Iosif",
      "email": "cristianiosif@me.com",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.3",
    "spatie/laravel-package-tools": "^1.92",
    "filament/filament": "^4.0|^5.0",
    "nikic/php-parser": "^5.0"
  },
  "require-dev": {
    "laravel/boost": "^2.3",
    "laravel/framework": "^12.0|^13.0",
    "laravel/pint": "^1.0",
    "orchestra/testbench": "^9.0|^10.0|^11.0",
    "pestphp/pest": "^3.0|^4.0",
    "pestphp/pest-plugin-laravel": "^3.0|^4.0",
    "phpunit/phpunit": "^10.0|^11.0|^12.0"
  },
  "autoload": {
    "psr-4": {
      "ribeiroconde\\Dictionary\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "ribeiroconde\\Dictionary\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "ribeiroconde\\Dictionary\\DictionaryServiceProvider"
      ]
    }
  },
  "scripts": {
    "test": "vendor/bin/pest",
    "format": "vendor/bin/pint",
    "lint": "vendor/bin/pint --test"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
